rules_version = '2';
// ═══════════════════════════════════════════════════════════════════
// codeSchool — Firestore Security Rules
// Project: codeschool-41f52
// Roles: admin | tutor | student
// Collections: users, courses, enrollments, payments, certificates,
//              submissions, examSubmissions, testResults,
//              notifications, questions, settings
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────
    // HELPERS
    // ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Reads the caller's user doc — cached per request by Firestore
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return myProfile().role;
    }

    function isAdmin() {
      return isSignedIn() && myRole() == 'admin';
    }

    function isTutor() {
      return isSignedIn() && myRole() == 'tutor';
    }

    function isStudent() {
      return isSignedIn() && myRole() == 'student';
    }

    function isActiveTutor() {
      return isTutor() && myProfile().status == 'active';
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Prevents any field from being changed that isn't in the allowed set
    function onlyFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // ──────────────────────────────────────────────────────────────
    // USERS
    // ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Admins see everyone. Users see themselves. Tutors can see
      // student profiles (needed for grading/submissions).
      allow read: if isMe(uid) || isAdmin() || isTutor();

      // Only admin can create user docs (registration flow via admin invite / backend)
      allow create: if isAdmin();

      // Admins can write anything.
      // Users can update their own doc but CANNOT change role, status,
      // registrationFeePaid, paystackSubaccountCode, or email.
      allow update: if isAdmin()
        || (isMe(uid) && onlyFields([
             'firstName','lastName','fullName','photoURL',
             'hiddenCourses','bio','phone'
           ]));

      // Only admin can delete accounts
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // COURSES
    // ──────────────────────────────────────────────────────────────
    match /courses/{courseId} {
      // Public browsing — anyone (even signed-out) can read live courses.
      // Admins and tutors can read all statuses (pending, draft, etc.)
      allow read: if resource.data.status == 'live'
        || isAdmin()
        || (isTutor() && resource.data.tutorId == request.auth.uid);

      // Active tutors can create courses (lands as status:'pending')
      allow create: if isActiveTutor()
        && request.resource.data.tutorId == request.auth.uid
        && request.resource.data.status == 'pending';

      // Tutors can update their own courses ONLY if not yet live/rejected.
      // Admins can update anything (approve, set price, reject, etc.)
      allow update: if isAdmin()
        || (isActiveTutor()
            && resource.data.tutorId == request.auth.uid
            && resource.data.status in ['pending', 'pending_edit', 'draft']);

      // Tutors can hard-delete their own draft/pending courses.
      // Admins can delete anything.
      allow delete: if isAdmin()
        || (isActiveTutor()
            && resource.data.tutorId == request.auth.uid
            && resource.data.status in ['pending', 'pending_edit', 'draft', 'deleted']);
    }

    // ──────────────────────────────────────────────────────────────
    // QUESTIONS  (course question bank, read by students during exam)
    // ──────────────────────────────────────────────────────────────
    match /questions/{questionId} {
      // Students can read questions for courses they're enrolled in.
      // Tutors can read/write questions for their own courses.
      // Admins can do anything.
      allow read: if isAdmin()
        || (isTutor() && resource.data.tutorId == request.auth.uid)
        || (isStudent() && exists(/databases/$(database)/documents/enrollments/$(request.auth.uid + '_' + resource.data.courseId)));

      allow write: if isAdmin()
        || (isActiveTutor() && request.resource.data.tutorId == request.auth.uid);
    }

    // ──────────────────────────────────────────────────────────────
    // ENROLLMENTS
    // ──────────────────────────────────────────────────────────────
    match /enrollments/{enrollId} {
      // Student sees their own. Tutor sees enrollments in their courses.
      // Admin sees all.
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.studentId == request.auth.uid)
        || (isTutor() && resource.data.tutorId == request.auth.uid);

      // Students create their own enrollments.
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;

      // Students can update their own enrollment (progress, completedLessons).
      // Admins can update anything.
      allow update: if isAdmin()
        || (isStudent()
            && resource.data.studentId == request.auth.uid
            && onlyFields(['completedLessons','progress','paid','paystackRef',
                           'certRequested','certIssued','certId','updatedAt']));

      // Only admin can delete enrollments
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // PAYMENTS
    // ──────────────────────────────────────────────────────────────
    match /payments/{payId} {
      // Admin sees all. Tutor sees payments for their courses.
      // Student sees their own payments.
      allow read: if isAdmin()
        || (isTutor() && resource.data.tutorId == request.auth.uid)
        || (isStudent() && resource.data.studentId == request.auth.uid);

      // Students and the system (via student dashboard) create payment records
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;

      // Only admin marks tutor payouts (tutorPaid, tutorPaidAt)
      allow update: if isAdmin();

      // No deletes — payment records are permanent audit trail
      allow delete: if false;
    }

    // ──────────────────────────────────────────────────────────────
    // CERTIFICATES
    // ──────────────────────────────────────────────────────────────
    match /certificates/{certId} {
      // Certs are publicly readable (shareable links)
      allow read: if true;

      // Students create their own cert requests.
      // Admins can create/overwrite any cert.
      allow create: if isAdmin()
        || (isStudent() && request.resource.data.studentId == request.auth.uid);

      // Students can update their own cert (e.g. mark paid).
      // Admins can update anything.
      allow update: if isAdmin()
        || (isStudent()
            && resource.data.studentId == request.auth.uid
            && onlyFields(['paid','locked','paidAt','paystackRef']));

      // Only admin can delete certs
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // ASSIGNMENT SUBMISSIONS
    // ──────────────────────────────────────────────────────────────
    match /submissions/{subId} {
      // Student sees their own. Tutor sees submissions for their courses.
      // Admin sees all.
      allow read: if isAdmin()
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || (isTutor() && resource.data.tutorId == request.auth.uid);

      // Students submit their own work
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;

      // Tutors grade (add score/feedback). Admins can update anything.
      allow update: if isAdmin()
        || (isTutor()
            && resource.data.tutorId == request.auth.uid
            && onlyFields(['score','feedback','graded','gradedAt']));

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // EXAM SUBMISSIONS
    // ──────────────────────────────────────────────────────────────
    match /examSubmissions/{subId} {
      allow read: if isAdmin()
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || (isTutor() && resource.data.tutorId == request.auth.uid);

      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;

      // Tutors grade exams. Admins can update anything.
      allow update: if isAdmin()
        || (isTutor()
            && resource.data.tutorId == request.auth.uid
            && onlyFields(['score','feedback','graded','gradedAt','passed']));

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // TEST RESULTS  (quick in-lesson knowledge checks)
    // ──────────────────────────────────────────────────────────────
    match /testResults/{resultId} {
      allow read: if isAdmin()
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || (isTutor() && resource.data.tutorId == request.auth.uid);

      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;

      // Test results are immutable after creation (no cheating)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // NOTIFICATIONS
    // ──────────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      // Users read notifs addressed to them or broadcast ('all').
      // Admins read everything.
      allow read: if isAdmin()
        || (isSignedIn()
            && (resource.data.userId == request.auth.uid
                || resource.data.target == 'all'
                || resource.data.target == request.auth.uid));

      // Only admin creates notifications
      allow create: if isAdmin();

      // Any signed-in user can mark their own notif as read.
      // Admins can write anything.
      allow update: if isAdmin()
        || (isSignedIn()
            && (resource.data.userId == request.auth.uid
                || resource.data.target == request.auth.uid
                || resource.data.target == 'all')
            && onlyFields(['read', 'readBy']));

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // SETTINGS  (revenue splits, activation fees, platform config)
    // ──────────────────────────────────────────────────────────────
    match /settings/{docId} {
      // All signed-in users can read settings (tutors need revenue split).
      // Only admin can write.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────────────────────
    // CATCH-ALL — deny everything not explicitly matched above
    // ──────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
