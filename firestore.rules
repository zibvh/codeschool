rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function myRole() {
      return myProfile().role;
    }

    function isAdmin() {
      return isSignedIn() && myRole() == 'admin';
    }

    function isTutor() {
      return isSignedIn() && myRole() == 'tutor';
    }

    function isStudent() {
      return isSignedIn() && myRole() == 'student';
    }

    function isActiveTutor() {
      return isTutor() && myProfile().status == 'active';
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /pending_users/{uid} {
      allow read: if isMe(uid) || isAdmin();
      allow create: if isMe(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == 'student'
        && request.resource.data.status == 'active';
      allow update: if isAdmin();
      allow delete: if isMe(uid) || isAdmin();
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        || (isMe(uid)
            && request.resource.data.uid == uid
            && request.resource.data.role == 'student'
            && request.resource.data.status == 'active');
      allow update: if isAdmin() || isMe(uid);
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow create: if isActiveTutor()
        && request.resource.data.tutorId == request.auth.uid
        && request.resource.data.status in ['pending', 'draft'];
      allow update: if isAdmin()
        || (isActiveTutor() && resource.data.tutorId == request.auth.uid);
      allow delete: if isAdmin()
        || (isActiveTutor()
            && resource.data.tutorId == request.auth.uid
            && resource.data.status in ['pending', 'pending_edit', 'draft', 'deleted']);
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin()
        || (isActiveTutor() && request.resource.data.tutorId == request.auth.uid);
    }

    match /enrollments/{enrollId} {
      allow read: if isSignedIn();
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin()
        || (isStudent() && resource.data.studentId == request.auth.uid);
    }

    match /payments/{payId} {
      allow read: if isSignedIn();
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /certificates/{certId} {
      allow read: if true;
      allow create: if isAdmin()
        || (isStudent() && request.resource.data.studentId == request.auth.uid);
      allow update: if isAdmin() || isStudent();
      allow delete: if isAdmin();
    }

    match /submissions/{subId} {
      allow read: if isSignedIn();
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || isTutor();
      allow delete: if isAdmin();
    }

    match /examSubmissions/{subId} {
      allow read: if isSignedIn();
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || isTutor();
      allow delete: if isAdmin();
    }

    match /testResults/{resultId} {
      allow read: if isSignedIn();
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn()
        && (resource.data.target == request.auth.uid
            || resource.data.target == 'all');
      allow create: if isAdmin() || isTutor() || isStudent();
      allow update: if isSignedIn()
        && (resource.data.target == request.auth.uid
            || resource.data.target == 'all');
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
